{"variants":[{"paths":["\/tutorials\/adaengine\/createfirst2dscene"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this tutorial you can learn how to create your first 2D scene using AdaEngine"}]}],"estimatedTimeInMinutes":20,"title":"Create your first 2D scene","xcodeRequirement":"Xcode 14.3 or later","chapter":"Create your first 2D game project.","kind":"hero","projectFiles":"CF2G-FirstPackage.zip"},{"kind":"tasks","tasks":[{"anchor":"Create-an-app","title":"Create an app","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For the first time, we should create base files to launch our application"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"code":"CF2G-1-1-app.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the previous tutorial we’ve created an app and an empty game scene."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-1-2-scene.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s create a game scene. To do this, let’s create a file named "},{"type":"codeVoice","code":"FirstScene.swift"},{"type":"text","text":" and import AdaEngine. After that, create a class named "},{"type":"codeVoice","code":"FirstScene"},{"type":"text","text":" and add a method named "},{"type":"codeVoice","code":"makeScene"},{"type":"text","text":" which returns an "},{"type":"codeVoice","code":"Scene"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"In this method we will create and configure our scene later."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-1-3-scene.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create the "},{"type":"codeVoice","code":"Scene"},{"type":"text","text":" instance in your "},{"type":"codeVoice","code":"FirstScene.swift"},{"type":"text","text":" file and return it."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-1-4-app.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Great! Now we can create and return our game scene instance to the "},{"type":"codeVoice","code":"GameAppScene"},{"type":"text","text":" object."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GameAppScene"},{"type":"text","text":" will automatically create a game window with your scene."}]}],"type":"step","runtimePreview":null,"media":null}]},{"anchor":"Create-a-main-camera","title":"Create a main camera.","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"AdaEngine used Entity Component System paradigm where all game objects are called "},{"type":"codeVoice","code":"Entity"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Entities are objects that store user or engine data like position, scale, mesh instance, audio etc. This data is called components and they should inherit from "},{"type":"codeVoice","code":"Component"},{"type":"text","text":" protocol."}]}],"mediaPosition":"trailing"},{"kind":"fullWidth","content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Camera"},{"type":"text","text":" is a component where all entities will render. AdaEngine supports rendering to the texture or to the "},{"type":"codeVoice","code":"Window"},{"type":"text","text":". We recommend you to use engine entities "},{"type":"codeVoice","code":"OrthographicCamera"},{"type":"text","text":" or "},{"type":"codeVoice","code":"PerspectiveCamera"},{"type":"text","text":", because the engine provides additional components for rendering and audio capabilities."}]}]}],"stepsSection":[{"code":"CF2G-2-1-camera.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s create our 2D camera. Create an "},{"type":"codeVoice","code":"OrthographicCamera"},{"type":"text","text":" entity and add this entity to the scene using the "},{"type":"codeVoice","code":"addEntity"},{"type":"text","text":" method."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-2-2-camera.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now let’s fill the camera background with sky blue color."}]}],"caption":[],"type":"step","runtimePreview":"CF2G-2-1.png","media":null}]},{"anchor":"First-sprite","title":"First sprite","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we can create our first custom sprite."}]}],"mediaPosition":"trailing"}],"stepsSection":[{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First we should create an assets folder where we will store our game assets, like sprite sheets, sounds, shaders, etc. Let’s create a folder named "},{"type":"codeVoice","code":"Assets"},{"type":"text","text":" and add any sprite sheets you want, we will use this next sprite sheet."}]}],"caption":[],"type":"step","runtimePreview":null,"media":"CF2G-3-1.png"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the end we should have this file structure in our project. AdaEngine doesn’t use xcassets and"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can download this texture using right click on image from right and save it to the downloads folder."}]}],"type":"step","runtimePreview":null,"media":"CF2G-3-2.png"},{"code":"CF2G-3-1-sprite.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a player entity and then add it to the scene. Player entity will store our sprite component and other player data."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-3-2-sprite.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s create an image from a file using a special resource manager object. "},{"type":"codeVoice","code":"ResourceManager"},{"type":"text","text":" manages and cache game and engine resources. In our case we should load an image from a file named "},{"type":"codeVoice","code":"characters_packed.png"},{"type":"text","text":" and use "},{"type":"codeVoice","code":"Bundle.main"},{"type":"text","text":" as a search path."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-3-3-sprite.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To split the sprite sheet image to sprites we can use the "},{"type":"codeVoice","code":"TextureAtlas"},{"type":"text","text":" object. This object gets an image, sprite size and margin between sprites if needed. In our case we have a margin between sprites 4xp horizontally and 1px vertically and sprite size 20px width and 23px height."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-3-4-sprite.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we can add our sprite to the player entity using special "},{"type":"codeVoice","code":"SpriteComponent"},{"type":"text","text":". These components are efficient for rendering, because they use a special batching system and require less drawing calls."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a new sprite component to entity components using the special "},{"type":"codeVoice","code":"+="},{"type":"text","text":" operator. As you can see we use subscripts in our TextureAtlas instance where 7 is the number of columns in our sprite sheet and 1 is the number of rows."}]}],"type":"step","runtimePreview":"CF2G-3-3.png","media":null},{"code":"CF2G-3-5-sprite.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"And finally let’s set the scale for our sprite. Create a special "},{"type":"codeVoice","code":"Transform"},{"type":"text","text":" component with scale equals 0.19. "},{"type":"codeVoice","code":"Vector3.init(_ scalar: Float)"},{"type":"text","text":" creates a vector with x, y, z components equals scalar value."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default "},{"type":"codeVoice","code":"Entity"},{"type":"text","text":" has a "},{"type":"codeVoice","code":"Transform"},{"type":"text","text":" component when initialized."}]}],"type":"step","runtimePreview":"CF2G-3-4.png","media":null}]},{"anchor":"Make-it-move","title":"Make it move","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We did a lot of work, but our scene looks very simple. We should add more life for our player entity. All game logic we describe in special objects named "},{"type":"codeVoice","code":"System"},{"type":"text","text":". System is a unit that executes each game loop and manipulates entities and their data. We will use one to add life for our player."}]}],"mediaPosition":"trailing"}],"stepsSection":[{"code":"CF2G-4-1-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First we should create a special tag component named "},{"type":"codeVoice","code":"PlayerComponent"},{"type":"text","text":". This component we will use in the near future and indicates for us that this entity is a player."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-2-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new system named "},{"type":"codeVoice","code":"MovementSystem"},{"type":"text","text":". This system will listen to user inputs and move our player component on the screen. System interface required "},{"type":"codeVoice","code":"init(scene:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"update(context:)"},{"type":"text","text":" methods."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-3-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a new system to our game scene. Our system will be created once the game scene will be active and present on the screen."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-4-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the "},{"type":"codeVoice","code":"MovementSystem"},{"type":"text","text":" add a static property named "},{"type":"codeVoice","code":"playerQuery"},{"type":"text","text":" and set a special "},{"type":"codeVoice","code":"EntityQuery"},{"type":"text","text":" object. This object will request a scene world with a special query and returns entities that conform to your predicate. In our case we will require two components in entity "},{"type":"codeVoice","code":"PlayerComponent"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Transform"},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Also add a property named "},{"type":"codeVoice","code":"speed"},{"type":"text","text":" which will store our player speed value."}]}],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-5-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we can make our first request to the scene using the special scene method "},{"type":"codeVoice","code":"performQuery"},{"type":"text","text":". This method will return a sequence of entities that conforms to our query."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the next query to the update method."}]}],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-6-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s iterate over all founded entities using the "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" loop and get the "},{"type":"codeVoice","code":"Transform"},{"type":"text","text":" component."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"We want to update our player position so that we should listen to keyboard inputs and if some key is pressed, we should change player transform."}]},{"code":"CF2G-4-6-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get "},{"type":"codeVoice","code":"Transform"},{"type":"text","text":" component from entity using "},{"type":"codeVoice","code":"components"},{"type":"text","text":" property from entity. You can do this using subscript."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-7-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"codeVoice","code":"if"},{"type":"text","text":" condition where we will listen to the "},{"type":"codeVoice","code":"w"},{"type":"text","text":" key. If the key is pressed, then add multiplication speed by delta time. We do this for smooth transition between frames."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-8-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we should set a new, modified transform to our entity, to apply a new transform in the scene."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CF2G-4-9-player.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, add the same logic for other keys - "},{"type":"codeVoice","code":"a"},{"type":"text","text":", "},{"type":"codeVoice","code":"s"},{"type":"text","text":" and "},{"type":"codeVoice","code":"d"},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Run the app and try to move your player"}]}],"type":"step","runtimePreview":"CF2G-3-5.mov","media":null}]}]}],"identifier":{"url":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene","interfaceLanguage":"swift"},"kind":"project","metadata":{"title":"Create your first 2D scene","categoryPathComponent":"AdaEngine","role":"project","category":"Ada Engine"},"hierarchy":{"modules":[{"reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/Create-your-first-2D-game-project.","projects":[{"reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateProject","sections":[{"kind":"task","reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateProject#Create-project-using-Xcode"}]},{"reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene","sections":[{"kind":"task","reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene#Create-an-app"},{"kind":"task","reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene#Create-a-main-camera"},{"kind":"task","reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene#First-sprite"},{"kind":"task","reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene#Make-it-move"}]}]}],"reference":"doc:\/\/AdaEngine\/tutorials\/AdaEngine","paths":[["doc:\/\/AdaEngine\/tutorials\/AdaEngine","doc:\/\/AdaEngine\/tutorials\/AdaEngine\/$volume","doc:\/\/AdaEngine\/tutorials\/AdaEngine\/Create-your-first-2D-game-project."]]},"references":{"CF2G-3-3.png":{"alt":"Our sprite sheet","type":"image","identifier":"CF2G-3-3.png","variants":[{"url":"\/images\/CF2G-3-3.png","traits":["1x","light"]}]},"doc://AdaEngine/tutorials/AdaEngine/Create-your-first-2D-game-project.":{"role":"article","title":"Create your first 2D game project.","abstract":[],"identifier":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/Create-your-first-2D-game-project.","kind":"article","type":"topic","url":"\/tutorials\/adaengine\/create-your-first-2d-game-project."},"CF2G-4-4-player.swift":{"syntax":"swift","content":["import AdaEngine","","class FirstScene {","    func makeScene() throws -> Scene {","        let scene = Scene()","        ","        let cameraEntity = OrthographicCamera()","        cameraEntity.camera.backgroundColor = Color(45\/255, 171\/255, 255\/255, 1)","        scene.addEntity(cameraEntity)","        ","        let spriteSheetImage = try ResourceManager.load(\"characters_packed.png\", from: .main) as Image","        let spriteSheet = TextureAtlas(from: spriteSheetImage, size: [20, 23], margin: [4, 1])","        ","        let playerEntity = Entity(name: \"Player\")","        playerEntity.components += SpriteComponent(texture: spriteSheet[7, 1])","        playerEntity.components += Transform(scale: Vector3(0.19))","        playerEntity.components += PlayerComponent()","        scene.addEntity(playerEntity)","        ","        scene.addSystem(MovementSystem.self)","        ","        return scene","    }","}","","struct PlayerComponent: Component {}","","struct MovementSystem: System {","    ","    private static let playerQuery = EntityQuery(where: .has(PlayerComponent.self) && .has(Transform.self))","    ","    let speed: Float = 3","    ","    init(scene: Scene) {","        ","    }","    ","    func update(context: UpdateContext) {","        ","    }","}"],"fileName":"FirstScene.swift","identifier":"CF2G-4-4-player.swift","type":"file","fileType":"swift","highlights":[{"line":29},{"line":30},{"line":31},{"line":32},{"line":33}]},"CF2G-3-2.png":{"alt":"Our sprite sheet","type":"image","identifier":"CF2G-3-2.png","variants":[{"url":"\/images\/CF2G-3-2.png","traits":["1x","light"]}]},"CF2G-3-5-sprite.swift":{"syntax":"swift","content":["import AdaEngine","","class FirstScene {","    func makeScene() throws -> Scene {","        let scene = Scene()","        ","        let cameraEntity = OrthographicCamera()","        cameraEntity.camera.backgroundColor = Color(45\/255, 171\/255, 255\/255, 1)","        scene.addEntity(cameraEntity)","        ","        let spriteSheetImage = try ResourceManager.load(\"characters_packed.png\", from: Bundle.main) as Image","        let spriteSheet = TextureAtlas(from: spriteSheetImage, size: [20, 23], margin: [4, 1])","        ","        let playerEntity = Entity(name: \"Player\")","        playerEntity.components += SpriteComponent(texture: spriteSheet[7, 1])","        playerEntity.components += Transform(scale: Vector3(0.19))","        scene.addEntity(playerEntity)","        ","        return scene","    }","}"],"fileName":"FirstScene.swift","identifier":"CF2G-3-5-sprite.swift","type":"file","fileType":"swift","highlights":[{"line":16}]},"CF2G-2-2-camera.swift":{"syntax":"swift","content":["import AdaEngine","","class FirstScene {","    func makeScene() throws -> Scene {","        let scene = Scene()","        ","        let cameraEntity = OrthographicCamera()","        cameraEntity.camera.backgroundColor = Color(45\/255, 171\/255, 255\/255, 1)","        scene.addEntity(cameraEntity)","        ","        return scene","    }","}"],"fileName":"FirstScene.swift","identifier":"CF2G-2-2-camera.swift","type":"file","fileType":"swift","highlights":[{"line":8}]},"doc://AdaEngine/tutorials/AdaEngine/CreateProject#Create-project-using-Xcode":{"role":"pseudoSymbol","title":"Create project using Xcode.","abstract":[{"type":"text","text":"In this tutorial you learn how to create your first AdaEngine project."}],"identifier":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateProject#Create-project-using-Xcode","kind":"section","type":"section","url":"\/tutorials\/adaengine\/createproject#Create-project-using-Xcode"},"CF2G-4-8-player.swift":{"syntax":"swift","content":["import AdaEngine","","class FirstScene {","    func makeScene() throws -> Scene {","        \/** Collapsed code *\/","    }","}","","struct PlayerComponent: Component {}","","struct MovementSystem: System {","    ","    private static let playerQuery = EntityQuery(where: .has(PlayerComponent.self) && .has(Transform.self))","    ","    let speed: Float = 3","    ","    init(scene: Scene) {","        