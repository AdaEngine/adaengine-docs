eVoice","code":"body"},{"type":"text","text":" property."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CP-2-3-app.swift","content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"App"},{"type":"text","text":" protocol requires us to implement "},{"type":"codeVoice","code":"scene"},{"type":"text","text":" property where we should pass our "},{"type":"codeVoice","code":"AppScene"},{"type":"text","text":" instance. "},{"type":"codeVoice","code":"AppScene"},{"type":"text","text":" tell the AdaEngine how to configure application and how to show app windows."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":"CP-2-4-app.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now add modification for your "},{"type":"codeVoice","code":"AppScene"},{"type":"text","text":". "},{"type":"codeVoice","code":"windowTitle"},{"type":"text","text":" modifier add custom window title for your window. "},{"type":"codeVoice","code":"windowMode"},{"type":"text","text":" modifier change window presentation from fullscreen to windowed."}]}],"caption":[],"type":"step","runtimePreview":null,"media":null},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, you can run you first project and you will see a black screen. That’s ok for empty scene."}]}],"caption":[],"type":"step","runtimePreview":null,"media":"CP-2-9.png"}]}]},{"action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"type":"reference","identifier":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateFirst2DScene","overridingTitle":"Get started"},"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Create your first 2D scene","abstract":[{"type":"text","text":"In this tutorial you can learn how to create your first 2D scene using AdaEngine"}]}],"identifier":{"url":"doc:\/\/AdaEngine\/tutorials\/AdaEngine\/CreateProject","interfaceLanguage":"swift"},"kind":